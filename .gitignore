# Rust / Cargo
target/
Cargo.lock

# Environment secrets — never commit these
.env
.env.contracts
.env.local

# Optimized WASM outputs
*.optimized.wasm

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Kiro IDE
.kiro/

# Pull-request drafts
pr-*.md

# Bindings — generated src/ and compiled dist/ are not committed.
# Only package.json and tsconfig.json scaffolds are tracked.
bindings/*/src/
bindings/*/dist/
bindings/*/node_modules/

# Soroban test snapshots — generated by the test harness, not source
**/test_snapshots/
