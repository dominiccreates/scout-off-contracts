# Rust / Cargo
target/
Cargo.lock

# Environment secrets — never commit these
.env
.env.contracts
.env.local

# Optimized WASM outputs
*.optimized.wasm

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Kiro IDE
.kiro/

# Pull-request drafts
pr-*.md

# Test snapshots
**/__snapshots__/
*.snap

# Node / frontend tooling (if any tooling is run locally)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Coverage reports
coverage/
lcov.info
tarpaulin-report.html

# Temporary and log files
*.log
*.tmp
*.bak

# Bindings — generated src/ and compiled dist/ are not committed.
# Only package.json and tsconfig.json scaffolds are tracked.
bindings/*/src/
bindings/*/dist/
bindings/*/node_modules/
