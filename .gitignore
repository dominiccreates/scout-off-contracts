# Rust / Cargo
target/
Cargo.lock

# Environment secrets — never commit these
.env
.env.contracts
.env.local

# Optimized WASM outputs
*.optimized.wasm
*.wasm

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Kiro IDE
.kiro/

# Pull-request drafts
pr-*.md

# Test snapshots generated by soroban test runner
**/test_snapshots/

# Bindings — generated src/ and compiled dist/ are not committed.
# Only package.json and tsconfig.json scaffolds are tracked.
bindings/*/src/
bindings/*/dist/
bindings/*/node_modules/

# Node / npm
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Compiled WASM artifacts
*.wasm

# Log files
*.log
