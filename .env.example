# ScoutChain Contracts — environment variables
# Copy to .env and fill in values before deploying

# Stellar keypair used to deploy and invoke contracts
DEPLOYER_SECRET=

# Admin G-address that will own all contracts
ADMIN_ADDRESS=

# Native XLM token contract address on the target network
# Testnet:  CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC
# Mainnet:  CAS3J7GYLGXMF6TDJBBYYSE3HQ6BBSMLNUQ34T6TZMYMW2EVH34XOWMA
XLM_TOKEN_ADDRESS=

# Target network: testnet | mainnet
STELLAR_NETWORK=testnet

# Horizon API endpoint
HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban RPC endpoint
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# SHA-256 hashes of deployed WASM binaries (written by scripts/deploy.sh)
REGISTRATION_CONTRACT_WASM_HASH=
VERIFICATION_CONTRACT_WASM_HASH=
PROGRESS_CONTRACT_WASM_HASH=
SCOUT_ACCESS_CONTRACT_WASM_HASH=
