root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Keep Rust editor settings aligned with rustfmt defaults.
[*.rs]
indent_style = space
indent_size = 4

[*.sh]
indent_style = space
indent_size = 2

[*.sql]
indent_style = space
indent_size = 4

[*.json]
indent_style = space
indent_size = 2

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.toml]
indent_style = space
indent_size = 4
